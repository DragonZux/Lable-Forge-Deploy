# Root environment template for docker compose.
# Copy this file to .env and replace placeholder values locally.

# Database / cache
MONGO_DB_NAME=labelforge

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=labelforge

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
SESSION_IDLE_TIMEOUT_MINUTES=30

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# App URLs
FRONTEND_URL=http://localhost:3333
BACKEND_URL=http://localhost:8000
# Optional public URL exposed by cloudflared/ngrok for Colab callbacks and dataset downloads.
BACKEND_PUBLIC_URL=
# Optional comma-separated origins for browser CORS, e.g. local dev plus ngrok/cloudflared domains.
CORS_ORIGINS=http://localhost:3000,http://localhost:3330,http://localhost:3333
# Optional comma-separated extra dev origins accepted by Next.js dev server.
NEXT_ALLOWED_DEV_ORIGINS=

# Colab Integration
GITHUB_USER=your-github-username
GITHUB_REPO=Train-Colab
GITHUB_BRANCH=main

# Email invitations
SEND_EMAILS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=LabelForge
