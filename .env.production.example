# Production environment template. Copy to your production secret manager or .env file.
# Do not commit real secret values.

# Database / cache
MONGO_DB_NAME=labelforge
MONGO_URI=mongodb://mongodb:27017
REDIS_URL=redis://redis:6379

# MinIO / S3-compatible storage
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=https://storage.example.com
MINIO_ACCESS_KEY=replace-with-storage-access-key
MINIO_SECRET_KEY=replace-with-storage-secret-key
MINIO_BUCKET_NAME=labelforge

# Auth
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
SESSION_IDLE_TIMEOUT_MINUTES=30
COOKIE_SECURE=true

# Browser / API origins
FRONTEND_URL=https://app.example.com
BACKEND_URL=https://api.example.com
BACKEND_PUBLIC_URL=https://api.example.com
CORS_ORIGINS=https://app.example.com,https://api.example.com
NEXT_PUBLIC_API_URL=/api
INTERNAL_API_URL=http://backend:8000/api
NEXT_ALLOWED_DEV_ORIGINS=

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com

# Colab / training integration
GITHUB_USER=your-github-username
GITHUB_REPO=Train-Colab
GITHUB_BRANCH=main

# Email invitations
SEND_EMAILS=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=LabelForge
